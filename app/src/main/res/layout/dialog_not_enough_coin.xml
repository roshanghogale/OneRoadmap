<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#F3F3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Marathi Message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="हि फाईल ओपन करण्यासाठी तुमच्या कडे पुरेसे Coin नाहीत. खालील पद्धतीने आणखी कॉईन Earn करू शकता!"
            android:textColor="#000"
            android:textSize="16sp"
            android:lineSpacingExtra="3dp"/>

        <!-- Coin Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Coin : "
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000"/>

            <TextView
                android:id="@+id/tv_coin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E60000"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageView
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/ic_warning"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#C9C9C9"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="18dp"/>

        <!-- Watch & Earn Button -->
        <RelativeLayout
            android:id="@+id/btn_watch"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_watch_button"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_watch"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Watch &amp; Earn"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"/>
            </LinearLayout>

            <TextView
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_coin_badge"
                android:padding="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="+150 Coin "
                android:textColor="#8B0000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_height="match_parent"
                android:layout_width="wrap_content"/>
        </RelativeLayout>

        <!-- Share & Earn Button -->
        <RelativeLayout
            android:id="@+id/btn_share"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_share_button"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_whatsapp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Share &amp; Earn"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"/>
            </LinearLayout>

            <TextView
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_coin_badge"
                android:padding="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text=" +50 Coin  "
                android:textColor="#8B0000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_height="match_parent"
                android:layout_width="wrap_content"/>
        </RelativeLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>