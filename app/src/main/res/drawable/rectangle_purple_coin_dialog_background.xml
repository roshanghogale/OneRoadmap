<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Stroke layer -->
    <item>
        <shape android:shape="rectangle">
            <solid
                android:color="#4B0082"/>
            <corners android:radius="24dp"/>
            <stroke android:color="#FFFFFF"
                android:width="2dp"/>
        </shape>
    </item>
</layer-list>

